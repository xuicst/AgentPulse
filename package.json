{
  "name": "AgentPulse",
  "displayName": "AgentPulse",
  "description": "AI Agent Notification Framework for VSCode",
  "version": "1.0.0",
  "publisher": "xuicst",
  "icon": "resources/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xuicst/AgentPulse"
  },
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "ai",
    "claude",
    "codex",
    "notification",
    "agent",
    "framework"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionKind": [
    "ui"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agentPulse.showOutput",
        "title": "AgentPulse: Show Output"
      },
      {
        "command": "agentPulse.restart",
        "title": "AgentPulse: Restart"
      },
      {
        "command": "agentPulse.about",
        "title": "AgentPulse: About"
      },
      {
        "command": "agentPulse.testNotification",
        "title": "AgentPulse: Test Notification"
      },
      {
        "command": "agentPulse.installCodexHook",
        "title": "AgentPulse: Enable Codex Notifications"
      },
      {
        "command": "agentPulse.installClaudeHook",
        "title": "AgentPulse: Enable Claude Notifications"
      }
    ],
    
    "configuration": {
      "title": "AgentPulse",
      "properties": {
        "agentPulse.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable AgentPulse."
        },

        "agentPulse.debug": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging."
        },

        "agentPulse.statusBar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show AgentPulse status bar."
        },

        "agentPulse.notifications.desktop": {
          "type": "boolean",
          "default": true,
          "description": "Enable desktop notifications."
        },

        "agentPulse.notifications.level": {
          "type": "string",
          "default": "important",
          "enum": [
            "all",
            "important",
            "none"
          ],
          "description": "Desktop notification level."
        },

        "agentPulse.notifications.permission": {
          "type": "boolean",
          "default": true,
          "description": "Notify when an agent requests permission."
        },
        "agentPulse.notifications.completed": {
          "type": "boolean",
          "default": true,
          "description": "Notify when an agent finishes."
        },
        "agentPulse.notifications.failed": {
          "type": "boolean",
          "default": true,
          "description": "Notify when an agent fails."
        },
        "agentPulse.notifications.cancelled": {
          "type": "boolean",
          "default": true,
          "description": "Notify when an agent is cancelled or denied."
        },

        "agentPulse.detectors.codex": {
          "type": "boolean",
          "default": true,
          "description": "Enable Codex detector."
        },

        "agentPulse.detectors.claude": {
          "type": "boolean",
          "default": true,
          "description": "Enable Claude detector."
        }

      }
    }
  },
  "scripts": {
    "check": "tsc --noEmit",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package:prepare": "npm run check && npm run compile",
    "package:native": "node scripts/build-native-helper.cjs",
    "package": "npm run package:win32-x64",
    "package:win32-x64": "npm run package:prepare && npm run package:native && node scripts/verify-native-helper.cjs win32-x64 && vsce package --target win32-x64 --ignoreFile .vscodeignore.win32-x64",
    "package:darwin-x64": "npm run package:prepare && vsce package --target darwin-x64 --ignoreFile .vscodeignore.darwin-x64",
    "package:darwin-arm64": "npm run package:prepare && vsce package --target darwin-arm64 --ignoreFile .vscodeignore.darwin-arm64",
    "package:linux-x64": "npm run package:prepare && npm run package:native && node scripts/verify-native-helper.cjs linux-x64 && vsce package --target linux-x64 --ignoreFile .vscodeignore.linux-x64",
    "package:linux-arm64": "npm run package:prepare && npm run package:native && node scripts/verify-native-helper.cjs linux-arm64 && vsce package --target linux-arm64 --ignoreFile .vscodeignore.linux-arm64"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.98.0",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.0"
  }
}
